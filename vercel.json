{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "frcwine.com" }],
      "destination": "https://www.frcwine.com/$1",
      "permanent": true
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "has": [{ "type": "host", "value": "wifi.freeruncellars.com" }],
      "destination": "/pages/wifi-welcome.html"
    },
    {
      "source": "/((?!api/).*)",
      "has": [{ "type": "host", "value": "wifi.freeruncellars.com" }],
      "destination": "/pages/wifi-welcome.html"
    }
  ]
}
