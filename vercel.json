{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "frcwine.com" }],
      "destination": "https://freeruncellars.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.frcwine.com" }],
      "destination": "https://freeruncellars.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "wifi.freeruncellars.com" }],
      "destination": "https://freeruncellars.com/pages/wifi-welcome",
      "permanent": false
    }
  ],
  "crons": [
    {
      "path": "/api/frost-alert-cron",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/weekend-forecast-cron",
      "schedule": "0 15 * * 5"
    }
  ],
  "headers": [
    {
      "source": "/robots.txt",
      "headers": [{ "key": "Content-Type", "value": "text/plain" }]
    }
  ],
  "rewrites": []
}
