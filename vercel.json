{
  "cleanUrls": true,
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "frcwine.com" }],
      "destination": "https://freeruncellars.com/$1",
      "permanent": true
    },
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "www.frcwine.com" }],
      "destination": "https://freeruncellars.com/$1",
      "permanent": true
    }
  ]
}
