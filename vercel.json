{
  "outputDirectory": ".",
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "frcwine.com" }],
      "destination": "https://www.frcwine.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/frost-alert-cron",
      "schedule": "0 11 * * *"
    },
    {
      "path": "/api/weekend-forecast-cron",
      "schedule": "0 15 * * 5"
    }
  ]
}
